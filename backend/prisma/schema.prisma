// Skema database CutwayWhatsApp — Tahap 0 (Fondasi)
// Mengacu ke Artefak 01: Desain Database & ERD CutwayWhatsApp
// Tabel Tahap 1+ (whatsapp_accounts, contacts, conversations, dst.) ditambahkan
// secara bertahap oleh Claude Code mengikuti roadmap di Artefak 05.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// KELOMPOK 1 — IDENTITAS & AKSES
// ============================================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String?   @unique
  passwordHash      String    @map("password_hash")
  fullName          String    @map("full_name")
  avatarFileId      String?   @map("avatar_file_id")
  isPlatformAdmin   Boolean   @default(false) @map("is_platform_admin")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  lastLoginAt       DateTime? @map("last_login_at")
  status            UserStatus @default(active)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  memberships       OrganizationMember[]
  refreshTokens     RefreshToken[]
  twoFactorSecret   TwoFactorSecret?

  @@map("users")
}

enum UserStatus {
  active
  disabled
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  familyId   String    @map("family_id")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  deviceInfo Json?     @map("device_info")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model TwoFactorSecret {
  id                    String    @id @default(uuid())
  userId                String    @unique @map("user_id")
  secretEncrypted       String    @map("secret_encrypted")
  backupCodesEncrypted  String[]  @map("backup_codes_encrypted")
  verifiedAt            DateTime? @map("verified_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_secrets")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id") // NULL = peran bawaan sistem
  name           String
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")

  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members           OrganizationMember[]
  rolePermissions   RolePermission[]

  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  key         String @unique
  module      String
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================================
// KELOMPOK 2 — ORGANISASI & BISNIS
// ============================================================

model Organization {
  id         String             @id @default(uuid())
  name       String
  slug       String             @unique
  industry   String?
  tier       OrganizationTier
  status     OrganizationStatus @default(trial)
  logoFileId String?            @map("logo_file_id")
  timezone   String             @default("Asia/Jakarta")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  deletedAt  DateTime?          @map("deleted_at")

  members  OrganizationMember[]
  roles    Role[]
  settings OrganizationSettings?

  @@index([slug])
  @@index([status])
  @@map("organizations")
}

enum OrganizationTier {
  personal
  umkm
  startup
  company
  enterprise
  government
}

enum OrganizationStatus {
  trial
  active
  suspended
  cancelled
}

model OrganizationMember {
  id             String                   @id @default(uuid())
  organizationId String                   @map("organization_id")
  userId         String                   @map("user_id")
  roleId         String                   @map("role_id")
  status         OrganizationMemberStatus @default(invited)
  invitedBy      String?                  @map("invited_by")
  joinedAt       DateTime?                @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

enum OrganizationMemberStatus {
  invited
  active
  suspended
}

model OrganizationSettings {
  id                String   @id @default(uuid())
  organizationId    String   @unique @map("organization_id")
  businessHours     Json?    @map("business_hours")
  autoReplyConfig   Json?    @map("auto_reply_config")
  dataRetentionDays Int      @default(90) @map("data_retention_days")
  branding          Json?
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}
