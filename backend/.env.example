# Salin file ini menjadi .env dan isi dengan nilai sungguhan.
# JANGAN PERNAH commit file .env asli ke Git.

NODE_ENV=development
PORT=3001

# Database (cocok dengan docker-compose.yml di root project)
DATABASE_URL="postgresql://cutway:cutway_dev_password@localhost:5432/cutwaywhatsapp?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — GANTI dengan nilai acak yang kuat sebelum produksi (minimal 32 karakter)
JWT_ACCESS_SECRET="ganti_dengan_rahasia_acak_yang_kuat_di_sini"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Frontend URL (untuk CORS)
FRONTEND_URL="http://localhost:3000"

# WhatsApp Cloud API (diisi saat Tahap 1 dibangun, lihat Artefak 01 Bagian 6.21)
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""

# Diisi saat modul Billing dibangun (Tahap 1)
STRIPE_SECRET_KEY=""

# Diisi saat modul AI Agent dibangun (Tahap 3)
ANTHROPIC_API_KEY=""
